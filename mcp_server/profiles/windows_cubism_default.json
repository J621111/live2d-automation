{
  "profile_name": "windows_cubism_default",
  "window_title_contains": "Cubism Editor",
  "window_probe_candidates": [
    "Cubism Editor",
    "Open",
    "Import PSD",
    "Template",
    "Confirm",
    "Export",
    "Overwrite"
  ],
  "import_shortcut": "^o",
  "template_shortcut": "^+t",
  "export_shortcut": "^+e",
  "launch_wait_seconds": 2.0,
  "activation_wait_seconds": 1.0,
  "dialog_wait_seconds": 0.8,
  "template_dialog_wait_seconds": 0.8,
  "export_dialog_wait_seconds": 1.0,
  "capture_screenshot_on_error": true,
  "failure_capture_wait_seconds": 0.2,
  "known_dialog_sequences": {
    "import_psd": [],
    "apply_template": [],
    "export_embedded_data": []
  },
  "known_dialog_recovery": {
    "import_psd": [
      {
        "title_contains": "Open",
        "keys": "~",
        "wait_seconds": 0.2
      },
      {
        "title_contains": "Import PSD",
        "keys": "%y",
        "wait_seconds": 0.2
      }
    ],
    "apply_template": [
      {
        "title_contains": "Template",
        "keys": "~",
        "wait_seconds": 0.2
      },
      {
        "title_contains": "Confirm",
        "keys": "%y",
        "wait_seconds": 0.2
      }
    ],
    "export_embedded_data": [
      {
        "title_contains": "Export",
        "keys": "~",
        "wait_seconds": 0.2
      },
      {
        "title_contains": "Overwrite",
        "keys": "%y",
        "wait_seconds": 0.2
      }
    ]
  },
  "retry_attempts": 1,
  "retry_backoff_seconds": 0.5,
  "action_retry_attempts": {
    "launch_editor": 1,
    "import_psd": 1,
    "apply_template": 1,
    "export_embedded_data": 1
  },
  "retry_recovery_sequences": {
    "default": [
      {
        "keys": "{ESC}",
        "wait_seconds": 0.2
      }
    ]
  }
}
